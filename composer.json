{
    "name": "bjornbasar/istrbuddy",
    "description": "Issue Tracking Buddy — a karhu-powered issue tracker",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.3",
        "bjornbasar/karhu": "^0.1",
        "bjornbasar/karhu-db": "dev-main"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "serve": "php -S localhost:8080 -t public",
        "test": "phpunit"
    }
}
